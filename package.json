{
    "name": "release-please-practice",
    "version": "4.5.0",
    "description": "Node.js application for release-please-practice",
    "author": "",
    "license": "ISC",
    "packageManager": "yarn@1.22.22",
    "main": "dist/",
    "scripts": {
        "ci": "yarn install --frozen-lockfile",
        "clean": "rimraf dist",
        "build": "tsc",
        "dev": "ts-node src/",
        "prebuild": "yarn run clean && yarn run lint && yarn run format",
        "start": "node dist/",
        "commitlint": "commitlint --edit $1",
        "lint": "eslint --ext .js,.ts .",
        "format": "prettier --write \"**/*.+(js|ts)\"",
        "docs": "typedoc --plugin typedoc-material-theme"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.34.0",
        "@types/node": "^24.3.0",
        "@typescript-eslint/eslint-plugin": "^8.40.0",
        "@typescript-eslint/parser": "^8.40.0",
        "eslint": "^9.34.0",
        "globals": "^16.3.0",
        "husky": "^9.1.7",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.10",
        "typedoc-material-theme": "^1.4.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.40.0"
    }
}
